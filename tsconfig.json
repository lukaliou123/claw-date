{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*", "api/**/*", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "data", ".doc", ".ref_projects"]
}
